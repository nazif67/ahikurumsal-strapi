{
  "kind": "collectionType",
  "collectionName": "habers",
  "info": {
    "singularName": "haber",
    "pluralName": "haberler",
    "displayName": "Haber",
    "description": "İş hukuku, mevzuat ve İK dünyasından haberler"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "date": {
      "type": "date"
    },
    "category": {
      "type": "enumeration",
      "enum": ["Genel", "İş Hukuku", "Mevzuat", "SGK & Sigorta", "Ücret & Tazminat", "İşe Alım"],
      "default": "Genel"
    },
    "coverImage": {
      "allowedTypes": ["images"],
      "type": "media",
      "multiple": false
    },
    "views": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "yorumlar": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::yorum.yorum",
      "mappedBy": "haber"
    }
  }
}
