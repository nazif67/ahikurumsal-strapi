{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog",
    "description": "Blog yazıları"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "date": {
      "type": "date"
    },
    "category": {
      "type": "string"
    },
    "coverImage": {
      "allowedTypes": ["images"],
      "type": "media",
      "multiple": false
    },
    "views": {
      "type": "integer",
      "default": 0,
      "min": 0
    }
  }
}
